# 飞书应用凭证（在飞书开放平台获取；本机已配 lark-cli 授权，亦可复用）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxx

# 飞书多维表格 app_token（数据库）
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxx

# 各表 table_id（在 P0 建表后填入）
TABLE_JUDGMENTS=tblxxxx
TABLE_PORTFOLIO=tblxxxx
TABLE_TASKS=tblxxxx
TABLE_DECISIONS=tblxxxx
TABLE_RISK_REVIEWS=tblxxxx
TABLE_INTEL=tblxxxx

# LLM（复盘点评用，OpenAI 兼容 API）
# 示例为 DeepSeek（OpenAI 兼容，无需改代码）：base=https://api.deepseek.com, model=deepseek-chat
# 也可换 OpenAI：base=https://api.openai.com/v1, model=gpt-4o-mini
LLM_API_KEY=sk-xxxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
